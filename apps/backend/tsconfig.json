{
  "extends": "../../packages/shared-config/tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "noEmit": false,
    "paths": {
      "@/*": ["./src/*"],
      "shared-types": ["../../packages/shared-types/src"],
      "shared-utils": ["../../packages/shared-utils/src"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
